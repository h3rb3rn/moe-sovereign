{
  "uid": "moe-inf-overview",
  "title": "MoE Inference — Overview (auto)",
  "tags": [
    "moe",
    "auto-generated",
    "inference"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "moe-prometheus"
        },
        "query": {
          "query": "label_values(node_uname_info, node)",
          "refId": "node"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Loaded models",
      "datasource": {
        "type": "prometheus",
        "uid": "moe-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "moe-prometheus"
          },
          "expr": "sum by (node) (ollama_loaded_models{job=\"ollama-endpoints\", node=~\"$node\"})",
          "legendFormat": "{{node}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "In-progress requests",
      "datasource": {
        "type": "prometheus",
        "uid": "moe-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "moe-prometheus"
          },
          "expr": "sum by (node) (ollama_requests_in_progress{job=\"ollama-endpoints\", node=~\"$node\"})",
          "legendFormat": "{{node}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pending queue",
      "datasource": {
        "type": "prometheus",
        "uid": "moe-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "moe-prometheus"
          },
          "expr": "sum by (node) (ollama_pending_requests{job=\"ollama-endpoints\", node=~\"$node\"})",
          "legendFormat": "{{node}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Ollama request rate (req/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "moe-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "moe-prometheus"
          },
          "expr": "sum by (node) (rate(ollama_request_duration_seconds_count{job=\"ollama-endpoints\", node=~\"$node\"}[2m]))",
          "legendFormat": "{{node}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Ollama p95 latency (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "moe-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "moe-prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le, node) (rate(ollama_request_duration_seconds_bucket{job=\"ollama-endpoints\", node=~\"$node\"}[5m])))",
          "legendFormat": "{{node}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU busy %",
      "datasource": {
        "type": "prometheus",
        "uid": "moe-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "moe-prometheus"
          },
          "expr": "100 - (avg by (node) (rate(node_cpu_seconds_total{job=\"inference-nodes\", mode=\"idle\", node=~\"$node\"}[2m])) * 100)",
          "legendFormat": "{{node}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Memory used %",
      "datasource": {
        "type": "prometheus",
        "uid": "moe-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "moe-prometheus"
          },
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{job=\"inference-nodes\", node=~\"$node\"} / node_memory_MemTotal_bytes{job=\"inference-nodes\", node=~\"$node\"}))",
          "legendFormat": "{{node}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Disk root used %",
      "datasource": {
        "type": "prometheus",
        "uid": "moe-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "moe-prometheus"
          },
          "expr": "100 - (node_filesystem_avail_bytes{job=\"inference-nodes\", mountpoint=\"/\", node=~\"$node\"} / node_filesystem_size_bytes{job=\"inference-nodes\", mountpoint=\"/\", node=~\"$node\"}) * 100",
          "legendFormat": "{{node}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Curator template invocations (rate 5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "moe-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "moe-prometheus"
          },
          "expr": "sum by (template) (rate(moe_template_invocations_total{template=~\"moe-ontology-curator.*\"}[5m]))",
          "legendFormat": "{{template}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true
}