# ==== MoE Sovereign — Environment Configuration ====
#
# Quickest path: do not edit this file directly. Run the bootstrap script
# for your platform — it generates a complete .env with random secrets:
#
#   Linux / WSL    sudo bash install.sh
#   macOS          bash scripts/bootstrap-macos.sh
#
# Both scripts are idempotent: re-running preserves existing secrets so
# they stay compatible with already-initialised data volumes.
#
# Manual setup: copy this template and fill in every REQUIRED block
# below before "docker compose up -d". Compose will refuse to start with
# an explicit error if any required password is missing.
#
#   cp .env.example .env
# =============================================================================

# ─── REQUIRED: host data roots (bind-mount sources) ─────────────────────────
# Where Postgres, Neo4j, Redis, ChromaDB, Kafka and logs live on the host.
#   Linux default: /opt/moe-infra
#   macOS:         ~/moe-data        (must be in Docker Desktop File Sharing)
#   Windows/WSL:   /home/<user>/moe-data
MOE_DATA_ROOT=/opt/moe-infra

# Grafana keeps its own root because operators often back it up separately.
#   Linux default: /opt/grafana
#   macOS:         ~/moe-grafana
GRAFANA_DATA_ROOT=/opt/grafana

# Optional: separate location for the few-shot example store.
# Defaults to ${MOE_DATA_ROOT}/few-shot when unset.
# FEW_SHOT_HOST_DIR=/opt/moe-infra/few-shot


# ─── REQUIRED: infrastructure passwords ─────────────────────────────────────
# Compose enforces these — `docker compose up` aborts with a clear error
# if any of them is empty. Generate each with `openssl rand -hex 16`
# (or 12 for Grafana, 32 for the secret key).
POSTGRES_CHECKPOINT_PASSWORD=
MOE_USERDB_PASSWORD=
REDIS_PASSWORD=
NEO4J_PASS=
GF_SECURITY_ADMIN_PASSWORD=

# MinIO S3 object storage (moe-storage) — file uploads and pre-signed URLs.
# Choose any username; password must be at least 8 characters.
# These become the root credentials for the MinIO admin console.
# Generate with: openssl rand -hex 24
MINIO_ROOT_USER=moe-admin
MINIO_ROOT_PASSWORD=

# Internal Docker hostname used by mcp-precision to upload files to MinIO.
# Do not change unless you rename the container in docker-compose.yml.
MINIO_ENDPOINT=moe-storage:9000

# Public-facing base URL rewritten into pre-signed download links returned in chat.
# Must match the reverse proxy hostname for files.<your-domain> in your Caddyfile.
MINIO_PUBLIC_URL=https://files.<your-domain>

# Connection URLs derived from the passwords above. Replace
# <password> with the matching value if you fill the .env by hand.
# REDIS_URL=redis://:<REDIS_PASSWORD>@terra_cache:6379/0
# POSTGRES_CHECKPOINT_URL=postgresql://langgraph:<POSTGRES_CHECKPOINT_PASSWORD>@terra_checkpoints:5432/langgraph
# MOE_USERDB_URL=postgresql://moe_admin:<MOE_USERDB_PASSWORD>@terra_checkpoints:5432/moe_userdb


# ─── REQUIRED: Admin UI / Dozzle credentials ───────────────────────────────
# Dozzle's bcrypt hash is generated from these on first start.
ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_SECRET_KEY=


# ─── Optional: Grafana admin user (defaults to "admin") ─────────────────────
# GF_SECURITY_ADMIN_USER=admin


# ─── Inference servers (configure via Admin UI after first boot) ────────────
# Optional pre-seed: a JSON array of GPU nodes the orchestrator may use.
# The Admin UI's Setup Wizard writes this for you — only set it manually
# for unattended deployments.
OLLAMA_API_KEY=ollama
INFERENCE_SERVERS='[{"name":"gpu-1","url":"http://localhost:11434/v1","gpu_count":1,"token":"ollama","api_type":"ollama","cost_factor":1.0,"vram_gb":12,"enabled":true,"timeout":3600}]'


# ─── Core routing (configure via Admin UI; defaults work for most setups) ──
JUDGE_MODEL=phi4:14b
JUDGE_ENDPOINT=gpu-1
PLANNER_MODEL=phi4:14b
PLANNER_ENDPOINT=gpu-1
GPU_COUNT=1


# ─── Optional: Expert routing tables ────────────────────────────────────────
# JSON map of expert categories → model lists. Use the Admin UI →
# Expert Templates page instead of editing by hand.
EXPERT_MODELS='{"general":[{"model":"gemma3:12b","endpoints":["gpu-1"],"enabled":true,"forced":true}]}'
# EXPERT_TEMPLATES='[]'


# ─── Logging & token accounting ────────────────────────────────────────────
LOG_LEVEL=INFO
TOKEN_PRICE_EUR=0.00002


# ─── ChromaDB ──────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb-vector
CHROMA_PORT=8000


# ─── GraphRAG context limits ───────────────────────────────────────────────
# Maximum characters injected from the knowledge graph into planner/merger prompts.
# Prevents context-window saturation on nodes with small LLMs (e.g. 8192-token models).
# Set to 0 to disable truncation (legacy behaviour).
MAX_GRAPH_CONTEXT_CHARS=6000


# ─── Cache tuning ──────────────────────────────────────────────────────────
SOFT_CACHE_THRESHOLD=0.50
CACHE_MIN_RESPONSE_LEN=150
EXPERT_TIER_BOUNDARY_B=20


# ─── Timeouts (seconds) ────────────────────────────────────────────────────
JUDGE_TIMEOUT=3600
EXPERT_TIMEOUT=3600
PLANNER_TIMEOUT=3600


# ─── Optional: web search ──────────────────────────────────────────────────
# SEARXNG_URL=https://search.example.com


# ─── Optional: Claude Code integration ─────────────────────────────────────
# CLAUDE_CODE_MODELS=claude-opus-4-6,claude-sonnet-4-6
# CLAUDE_CODE_MODE=moe_orchestrated
# CLAUDE_CODE_TOOL_MODEL=gemma3:12b
# CLAUDE_CODE_TOOL_ENDPOINT=gpu-1
# CLAUDE_CODE_PROFILES='[]'


# ─── Optional: SMTP for password-reset / admin notification mails ──────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.org
# SMTP_STARTTLS=true


# ─── Optional: OIDC SSO ─────────────────────────────────────────────────────
# OIDC_ISSUER=https://authentik.example.org/application/o/moe/
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://admin.example.org/auth/callback
# OIDC_JWKS_URL=https://authentik.example.org/application/o/moe/jwks/


# ─── Optional: public URLs (for invite mails, OIDC redirects, docs links) ──
# DOMAIN=
# PUBLIC_ADMIN_URL=https://admin.example.org
# PUBLIC_API_URL=https://api.example.org
# APP_BASE_URL=https://moe-sovereign.example.org


# ─── Optional: CORS for browser clients ─────────────────────────────────────
# CORS_ORIGINS=https://chat.example.org,https://admin.example.org
# CORS_ALL_ORIGINS=0


# ─── Optional: published host ports ────────────────────────────────────────
# Override any of these to avoid collisions on the host (e.g. when port 80
# or 8088 is already in use). Container-internal ports are not affected.
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
# ADMIN_UI_HOST_PORT=8088
# LANGGRAPH_HOST_PORT=8002
# MCP_HOST_PORT=8003
# DOCS_HOST_PORT=8098
# GRAFANA_HOST_PORT=3001
# CHROMA_HOST_PORT=8001
# PROMETHEUS_HOST_PORT=9090
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687
# KAFKA_HOST_PORT=9092
# DOZZLE_HOST_PORT=9999
# NODE_EXPORTER_HOST_PORT=9100
# CADVISOR_HOST_PORT=9338

# ─── Optional: LLM Fallback ─────────────────────────────────────────────────
# When a remote LLM endpoint is transiently unstable, the orchestrator retries
# and then falls back to a local inference node. Leave empty to disable.
# Node name must match an entry in INFERENCE_SERVERS (admin UI → Configuration).
# AIHUB_FALLBACK_NODE=
# AIHUB_FALLBACK_MODEL=
# AIHUB_FALLBACK_MODEL_SECOND=

# --- Security ---
# Maximum request body size in MB (default: 16). Increase only if you upload large attachments.
# MAX_REQUEST_BODY_MB=16
# Maximum API requests per minute per IP address (default: 60). Reduce on public deployments.
# MAX_REQUESTS_PER_MINUTE=60


# ─── STARFLEET FEATURES (ambient intelligence — Star Trek computer capabilities) ──
# All features can also be toggled at runtime via Redis without a container restart:
#   redis-cli SET moe:features:watchdog true|false
#   redis-cli SET moe:features:mission_context true|false
#   redis-cli SET moe:features:adaptive_ui true|false
#   redis-cli SET moe:features:infra_mcp true|false
#
# Proactive Watchdog: pushes alerts to Valkey + Kafka when nodes go down or VRAM is high.
# Does NOT add new HTTP polling — reads data already collected by the gauge loop.
WATCHDOG_ENABLED=true
# How many consecutive 60s cycles a node must be unreachable before a NODE_DOWN alert fires.
WATCHDOG_DOWN_THRESHOLD=2
# Evaluation interval in seconds (note: data freshness is still bound by the 60s gauge loop).
WATCHDOG_INTERVAL_SECONDS=60
# VRAM usage threshold (0.0–1.0) above which a VRAM_HIGH alert is emitted per node.
WATCHDOG_VRAM_THRESHOLD=0.90

# Persistent Mission Context: cross-session JSON file storing current project state.
# Written to $MOE_DATA_ROOT/mission_context.json — zero extra DB dependency.
MISSION_CONTEXT_ENABLED=true

# Adaptive LCARS Dashboard: /starfleet in Admin UI, color-coded by system state.
# Purely frontend — no additional polling, reads existing Valkey/Prometheus data.
ADAPTIVE_UI_ENABLED=true

# Infra MCP Tools: read-only node_status / active_requests / watchdog_alerts / mission_context
# accessible via MCP tool calls from the orchestrator. Conservative default: off.
# Enable only when you want the AI to introspect its own infrastructure.
INFRA_MCP_ENABLED=false
