# ==== MoE Sovereign — Environment Configuration ====
#
# Quickest path: do not edit this file directly. Run the bootstrap script
# for your platform — it generates a complete .env with random secrets:
#
#   Linux / WSL    sudo bash install.sh
#   macOS          bash scripts/bootstrap-macos.sh
#
# Both scripts are idempotent: re-running preserves existing secrets so
# they stay compatible with already-initialised data volumes.
#
# Manual setup: copy this template and fill in every REQUIRED block
# below before "docker compose up -d". Compose will refuse to start with
# an explicit error if any required password is missing.
#
#   cp .env.example .env
# =============================================================================

# ─── REQUIRED: host data roots (bind-mount sources) ─────────────────────────
# Where Postgres, Neo4j, Redis, ChromaDB, Kafka and logs live on the host.
#   Linux default: /opt/moe-infra
#   macOS:         ~/moe-data        (must be in Docker Desktop File Sharing)
#   Windows/WSL:   /home/<user>/moe-data
MOE_DATA_ROOT=/opt/moe-infra

# Grafana keeps its own root because operators often back it up separately.
#   Linux default: /opt/grafana
#   macOS:         ~/moe-grafana
GRAFANA_DATA_ROOT=/opt/grafana

# Optional: separate location for the few-shot example store.
# Defaults to ${MOE_DATA_ROOT}/few-shot when unset.
# FEW_SHOT_HOST_DIR=/opt/moe-infra/few-shot


# ─── REQUIRED: infrastructure passwords ─────────────────────────────────────
# Compose enforces these — `docker compose up` aborts with a clear error
# if any of them is empty. Generate each with `openssl rand -hex 16`
# (or 12 for Grafana, 32 for the secret key).
POSTGRES_CHECKPOINT_PASSWORD=
MOE_USERDB_PASSWORD=
REDIS_PASSWORD=
NEO4J_PASS=
GF_SECURITY_ADMIN_PASSWORD=

# MinIO S3 object storage (moe-storage) — file uploads and pre-signed URLs.
# Choose any username; password must be at least 8 characters.
# These become the root credentials for the MinIO admin console.
# Generate with: openssl rand -hex 24
MINIO_ROOT_USER=moe-admin
MINIO_ROOT_PASSWORD=

# Internal Docker hostname used by mcp-precision to upload files to MinIO.
# Do not change unless you rename the container in docker-compose.yml.
MINIO_ENDPOINT=moe-storage:9000

# Public-facing base URL rewritten into pre-signed download links returned in chat.
# Must match the reverse proxy hostname for files.<your-domain> in your Caddyfile.
MINIO_PUBLIC_URL=https://files.<your-domain>

# Connection URLs derived from the passwords above. Replace
# <password> with the matching value if you fill the .env by hand.
# REDIS_URL=redis://:<REDIS_PASSWORD>@terra_cache:6379/0
# POSTGRES_CHECKPOINT_URL=postgresql://langgraph:<POSTGRES_CHECKPOINT_PASSWORD>@terra_checkpoints:5432/langgraph
# MOE_USERDB_URL=postgresql://moe_admin:<MOE_USERDB_PASSWORD>@terra_checkpoints:5432/moe_userdb


# ─── REQUIRED: Admin UI / Dozzle credentials ───────────────────────────────
# Dozzle's bcrypt hash is generated from these on first start.
ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_SECRET_KEY=


# ─── Optional: Grafana admin user (defaults to "admin") ─────────────────────
# GF_SECURITY_ADMIN_USER=admin


# ─── Inference servers (configure via Admin UI after first boot) ────────────
# Optional pre-seed: a JSON array of GPU nodes the orchestrator may use.
# The Admin UI's Setup Wizard writes this for you — only set it manually
# for unattended deployments.
OLLAMA_API_KEY=ollama
INFERENCE_SERVERS='[{"name":"gpu-1","url":"http://localhost:11434/v1","gpu_count":1,"token":"ollama","api_type":"ollama","cost_factor":1.0,"vram_gb":12,"enabled":true,"timeout":3600}]'

# Anthropic / AIHUB example (api_type="anthropic" activates prompt caching in cache_aligner.py):
# INFERENCE_SERVERS='[
#   {"name":"gpu-1","url":"http://localhost:11434/v1","gpu_count":1,"token":"ollama","api_type":"ollama","cost_factor":1.0,"vram_gb":12,"enabled":true,"timeout":3600},
#   {"name":"aihub-anthropic","url":"https://api.anthropic.com","token":"sk-ant-YOUR_KEY","api_type":"anthropic","cost_factor":10.0,"vram_gb":0,"enabled":true,"timeout":120}
# ]'


# ─── Core routing (configure via Admin UI; defaults work for most setups) ──
JUDGE_MODEL=phi4:14b
JUDGE_ENDPOINT=gpu-1
PLANNER_MODEL=phi4:14b
PLANNER_ENDPOINT=gpu-1
GPU_COUNT=1


# ─── Optional: Expert routing tables ────────────────────────────────────────
# JSON map of expert categories → model lists. Use the Admin UI →
# Expert Templates page instead of editing by hand.
EXPERT_MODELS='{"general":[{"model":"gemma3:12b","endpoints":["gpu-1"],"enabled":true,"forced":true}]}'
# EXPERT_TEMPLATES='[]'


# ─── Logging & token accounting ────────────────────────────────────────────
LOG_LEVEL=INFO
TOKEN_PRICE_EUR=0.00002


# ─── ChromaDB ──────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb-vector
CHROMA_PORT=8000


# ─── GraphRAG context limits ───────────────────────────────────────────────
# Maximum characters injected from the knowledge graph into planner/merger prompts.
# Prevents context-window saturation on nodes with small LLMs (e.g. 8192-token models).
# Set to 0 to disable truncation (legacy behaviour).
MAX_GRAPH_CONTEXT_CHARS=6000


# ─── Cache tuning ──────────────────────────────────────────────────────────
SOFT_CACHE_THRESHOLD=0.50
CACHE_MIN_RESPONSE_LEN=150
EXPERT_TIER_BOUNDARY_B=20


# ─── Timeouts (seconds) ────────────────────────────────────────────────────
JUDGE_TIMEOUT=3600
EXPERT_TIMEOUT=3600
PLANNER_TIMEOUT=3600


# ─── Optional: web search ──────────────────────────────────────────────────
# SEARXNG_URL=https://search.example.com


# ─── Optional: Claude Code integration ─────────────────────────────────────
# CLAUDE_CODE_MODELS=claude-opus-4-6,claude-sonnet-4-6
# CLAUDE_CODE_MODE=moe_orchestrated
# CLAUDE_CODE_TOOL_MODEL=gemma3:12b
# CLAUDE_CODE_TOOL_ENDPOINT=gpu-1
# CLAUDE_CODE_PROFILES='[]'


# ─── Optional: SMTP for password-reset / admin notification mails ──────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.org
# SMTP_STARTTLS=true


# ─── Optional: OIDC SSO ─────────────────────────────────────────────────────
# OIDC_ISSUER=https://authentik.example.org/application/o/moe/
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://admin.example.org/auth/callback
# OIDC_JWKS_URL=https://authentik.example.org/application/o/moe/jwks/


# ─── Optional: public URLs (for invite mails, OIDC redirects, docs links) ──
# DOMAIN=
# PUBLIC_ADMIN_URL=https://admin.example.org
# PUBLIC_API_URL=https://api.example.org
# APP_BASE_URL=https://moe-sovereign.example.org


# ─── Optional: CORS for browser clients ─────────────────────────────────────
# Required when Open WebUI or browser clients call the API directly (e.g. connection test).
# CORS_ORIGINS=https://chat.example.org,https://admin.example.org
CORS_ALL_ORIGINS=1


# ─── Optional: published host ports ────────────────────────────────────────
# Override any of these to avoid collisions on the host (e.g. when port 80
# or 8088 is already in use). Container-internal ports are not affected.
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
# ADMIN_UI_HOST_PORT=8088
# LANGGRAPH_HOST_PORT=8002
# MCP_HOST_PORT=8003
# DOCS_HOST_PORT=8098
# GRAFANA_HOST_PORT=3001
# CHROMA_HOST_PORT=8001
# PROMETHEUS_HOST_PORT=9090
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687
# KAFKA_HOST_PORT=9092
# DOZZLE_HOST_PORT=9999
# NODE_EXPORTER_HOST_PORT=9100
# CADVISOR_HOST_PORT=9338

# ─── Optional: Codex external UI URLs ──────────────────────────────────────
# Public-facing URL for the Apache Superset BI frontend.
# Used by the "Open Superset UI" button in the Analytics & BI admin page.
# Set to the URL your browser can reach, e.g.:
#   https://bi.yourdomain.com          (dedicated Caddy subdomain)
#   http://your-server-ip:8889         (direct port access)
# Leave empty to disable the button (shows a tooltip instead).
# SUPERSET_EXTERNAL_URL=

# Public-facing URL for the Budibase no-code builder (Workshop page).
# Used by "Open Budibase Builder" button. Example: https://apps.yourdomain.com
# or http://your-server-ip:10000
# BUDIBASE_EXTERNAL_URL=

# Public-facing URL for the HedgeDoc collaborative notes instance (Notes page).
# Used by "Open HedgeDoc" button and for direct note edit links.
# Example: https://notes.yourdomain.com or http://your-server-ip:3000
# HEDGEDOC_EXTERNAL_URL=

# ─── Optional: LLM Fallback ─────────────────────────────────────────────────
# When a remote LLM endpoint is transiently unstable, the orchestrator retries
# and then falls back to a local inference node. Leave empty to disable.
# Node name must match an entry in INFERENCE_SERVERS (admin UI → Configuration).
# FALLBACK_NODE=                   # name of the local fallback inference server
# FALLBACK_MODEL=                  # primary fallback model on that node
# FALLBACK_MODEL_SECOND=           # optional second fallback model (chain fallback)
#
# Retry / degraded-window tuning (optional — defaults shown):
# ENDPOINT_RETRY_COUNT=3           # retries before declaring endpoint degraded
# ENDPOINT_RETRY_DELAY=2.0         # seconds between retries
# ENDPOINT_DEGRADED_TTL=300        # blackout window in seconds after auth/quota failure
#
# URL substring patterns that identify external (non-local) endpoints.
# Comma-separated list; matched case-insensitively against the endpoint URL.
# EXTERNAL_ENDPOINT_PATTERNS=      # e.g. my-cloud-api,provider.example.com
#
# Legacy names still accepted for backward compat (no action needed if already set):
# AIHUB_FALLBACK_NODE=             # use FALLBACK_NODE instead
# AIHUB_FALLBACK_MODEL=            # use FALLBACK_MODEL instead
# AIHUB_FALLBACK_MODEL_SECOND=     # use FALLBACK_MODEL_SECOND instead

# --- Security ---
# Maximum request body size in MB (default: 16). Increase only if you upload large attachments.
# MAX_REQUEST_BODY_MB=16
# Maximum API requests per minute per IP address (default: 60). Reduce on public deployments.
# MAX_REQUESTS_PER_MINUTE=60


# ─── STARFLEET FEATURES (ambient intelligence — Star Trek computer capabilities) ──
# All features can also be toggled at runtime via Redis without a container restart:
#   redis-cli SET moe:features:watchdog true|false
#   redis-cli SET moe:features:mission_context true|false
#   redis-cli SET moe:features:adaptive_ui true|false
#   redis-cli SET moe:features:infra_mcp true|false
#
# Proactive Watchdog: pushes alerts to Valkey + Kafka when nodes go down or VRAM is high.
# Does NOT add new HTTP polling — reads data already collected by the gauge loop.
WATCHDOG_ENABLED=true
# How many consecutive 60s cycles a node must be unreachable before a NODE_DOWN alert fires.
WATCHDOG_DOWN_THRESHOLD=2
# Evaluation interval in seconds (note: data freshness is still bound by the 60s gauge loop).
WATCHDOG_INTERVAL_SECONDS=60
# VRAM usage threshold (0.0–1.0) above which a VRAM_HIGH alert is emitted per node.
WATCHDOG_VRAM_THRESHOLD=0.90

# Persistent Mission Context: cross-session JSON file storing current project state.
# Written to $MOE_DATA_ROOT/mission_context.json — zero extra DB dependency.
MISSION_CONTEXT_ENABLED=true

# Adaptive LCARS Dashboard: /starfleet in Admin UI, color-coded by system state.
# Purely frontend — no additional polling, reads existing Valkey/Prometheus data.
ADAPTIVE_UI_ENABLED=true

# Infra MCP Tools: read-only node_status / active_requests / watchdog_alerts / mission_context
# accessible via MCP tool calls from the orchestrator. Conservative default: off.
# Enable only when you want the AI to introspect its own infrastructure.
INFRA_MCP_ENABLED=false

# =============================================================================
# Optional: Enterprise Data Management Stack
# Set by install.sh when user opts in. Requires docker-compose.enterprise.yml.
# =============================================================================
INSTALL_ENTERPRISE_DATA_STACK=false

# Apache NiFi — Data Flow Automation (ETL for legacy systems)
NIFI_URL=http://moe-nifi:8080
NIFI_ADMIN_USER=admin
# NiFi single-user password (min 12 chars)
NIFI_ADMIN_PASSWORD=nifi-changeme-pwd
NIFI_HOST_PORT=8181
# Optional: ListenHTTP processor URL for forwarding knowledge events into NiFi flows.
# Empty = disabled. The orchestrator will fire-and-forget POST JSON payloads here
# whenever a knowledge bundle is imported or a kafka_ingest event is processed.
NIFI_INGEST_URL=
NIFI_SUBMIT_TIMEOUT=3.0

# OpenLineage / Marquez — Data Lineage Backend
MARQUEZ_URL=http://moe-marquez:5000
# IMPORTANT: marquez.dev.yml inside the marquezproject/marquez image hardcodes
# `password: marquez` literally and ignores POSTGRES_PASSWORD. Override the
# default Postgres password to "marquez" so the embedded dev-config can connect.
# For prod, mount your own marquez.yml with ${POSTGRES_PASSWORD} interpolation.
MARQUEZ_POSTGRES_PASSWORD=marquez
MARQUEZ_HOST_PORT=5000
MARQUEZ_ADMIN_PORT=5001
MARQUEZ_WEB_PORT=3030

# lakeFS — Data Version Control (Git-like branching for datasets)
LAKEFS_ENDPOINT=http://moe-lakefs:8000
LAKEFS_DB_PASSWORD=lakefs-changeme
# Must be exactly 32 bytes
LAKEFS_ENCRYPT_SECRET=changeme-must-be-32bytes-long!!
LAKEFS_ACCESS_KEY_ID=lakefs-access-key-changeme
LAKEFS_SECRET_ACCESS_KEY=lakefs-secret-key-changeme
LAKEFS_HOST_PORT=8010

# JupyterLite (Phase 24) — embedded notebook URL.
# Default points at the official public demo (browser-only WebAssembly Jupyter).
# For offline/self-hosted: serve a JupyterLite build under /opt/.../static/jl/
# behind your reverse proxy and point this at https://<host>/jl/lab/index.html.
JUPYTERLITE_URL=https://jupyterlite.github.io/demo/lab/index.html

# Claude Code (CC) session history compression.
# Truncate history when it exceeds THRESHOLD tokens; keep only the last
# KEEP_TURNS full turns. Helps prevent context-overflow in long sessions.
CC_HISTORY_COMPRESS_THRESHOLD=3000
CC_HISTORY_COMPRESS_KEEP_TURNS=2

# Knowledge-bypass cache tier — a query that is similar (but not an exact L1 hit)
# to a prior answer skips the LLM when that answer was high-confidence and is
# still fresh. Conservative: threshold stays above CACHE_HIT_THRESHOLD (0.15).
KNOWLEDGE_BYPASS_ENABLED=true
KNOWLEDGE_BYPASS_THRESHOLD=0.25
KNOWLEDGE_BYPASS_MIN_CONF=0.85
KNOWLEDGE_BYPASS_TTL_DAYS=14

# Routing bandit — contextual Thompson bandit that learns the retrieval gates
# (research / graphrag) from request outcomes. Until both arms of a (gate,context)
# reach MIN_DATAPOINTS, the fuzzy/complexity heuristic is used as cold-start
# fallback. COST_PRIOR biases ties toward skipping retrieval; CONTEXT_BANDS is the
# t-norm discretisation granularity (2 = low/high → faster learning).
ROUTING_BANDIT_ENABLED=true
ROUTING_BANDIT_MIN_DATAPOINTS=20
ROUTING_BANDIT_COST_PRIOR=0.5
ROUTING_BANDIT_CONTEXT_BANDS=2

# Trivial fast-path (opt-in, OFF by default): a trivial query the semantic router
# did not already route skips the planner LLM call and goes straight to a single
# default-category expert. Saves one LLM call per trivial request but forces a
# default expert for unmatched trivial queries — enable only after measuring.
TRIVIAL_FAST_PATH_ENABLED=false
TRIVIAL_FAST_PATH_CATEGORY=general

# Trivial low-confidence rescue (ON by default): when a trivial query is cost-tier
# limited to a single Tier-1 expert, still allow a Tier-2 (large model) rescue if
# the T1 answer comes back low-confidence or empty. Medium/high T1 answers keep the
# cost saving — only genuine garbage escalates. Set to false for the strict
# "trivial never touches Tier-2" behaviour.
TRIVIAL_LOW_CONF_RESCUE_ENABLED=true

# GraphRAG text-to-Cypher (T2C) — translate questions into Cypher for precise
# graph retrieval, bounded by a node cap and timeout.
GRAPHRAG_T2C_ENABLED=1
GRAPHRAG_T2C_TIMEOUT=8.0
GRAPHRAG_T2C_MAX_NODES=8

# GraphRAG query reformulation — rewrite the query for better graph matching.
GRAPHRAG_REFORMULATE_ENABLED=1
GRAPHRAG_REFORMULATE_TIMEOUT=5.0

# User conversation audit log — per-user JSONL of prompts/responses + routing
# metadata, with configurable retention (days) capped at RETENTION_MAX.
CONVERSATION_LOG_ENABLED=true
CONVERSATION_LOG_RETENTION_DAYS_DEFAULT=90
CONVERSATION_LOG_RETENTION_MAX=365
CONVERSATION_LOG_DIR=/app/logs/users

# --- Hermes Kanban Integration ---
# Host-side path to the Hermes kanban workspaces directory.
# When set, completed kanban task results are written as files (result.html / result.md)
# into the corresponding workspace subdirectory, accessible outside the database.
# Leave empty to disable workspace file writing (default).
# Example: HERMES_KANBAN_WORKSPACES_HOST=/opt/hermes/kanban/workspaces
HERMES_KANBAN_WORKSPACES_HOST=

# --- Context Window Size & Token Limits Settings ---
AGENTIC_GAP_THRESHOLD_TOKENS=8192
CC_CONTEXT_INDEX_ENABLED=true
# Tier-2/Tier-3 embedding endpoint for semantic memory and context-index upserts.
# Point at the dedicated CPU sidecar (moe-embed) — never a GPU inference node,
# whose Ollama scheduler will starve embedding requests behind long generations.
SEMANTIC_MEMORY_EMBED_MODEL=ollama:nomic-embed-text
SEMANTIC_MEMORY_EMBED_URL=http://moe-embed:11434
CC_PREANALYSIS_DELAY_SECS=0.5
CC_SAFETY_BUFFER_TOKENS=500
COT_MIN_CATEGORIES=2
COT_MIN_TASKS=2
EXPERT_CHARS_PER_TOKEN=3
EXPERT_INPUT_MIN_CHARS=2000
EXPERT_OUTPUT_DIVISOR=4
JUDGE_NUM_CTX=32768
MAX_EXPERT_OUTPUT_CHARS_CODE=48000
MAX_EXPERT_TOKENS=4096
MAX_EXPERT_TOKENS_CODE=16384
MAX_JUDGE_TOKENS=8192
MAX_PLANNER_TOKENS=8192
PLANNER_NUM_CTX=32768
WM_EXTRACT_THRESHOLD_TOKENS=8192

# Claude Code Summarization-on-Drop settings
CC_HISTORY_COMPRESS_LLM=
CC_HISTORY_COMPRESS_LLM_TIMEOUT=15.0

# RouteLLM Configurations
# ROUTELLM_ENABLED=true
# ROUTELLM_THRESHOLD=0.5
# ROUTELLM_WEIGHTS_PATH=/app/models/routellm_bge_weights.json

# J-MoE Debate Configurations
# JMOE_DEBATE_ENABLED=true

# ── PM Connector (MCP tools: pm_create_task / pm_list_tasks / pm_update_task / pm_search_tasks) ──
# PM_BACKEND=          # linear | github | webhook  (leave empty to disable)
# PM_API_KEY=          # Linear personal API key | GitHub PAT | webhook bearer token
# PM_PROJECT_ID=       # Linear team ID | GitHub "owner/repo" | webhook project slug
# PM_BASE_URL=         # optional: override API base URL (e.g. self-hosted GitHub Enterprise)
# PM_DEFAULT_LABELS=moe-ai  # comma-separated labels added to every created task
