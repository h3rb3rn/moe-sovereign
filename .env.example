# ==== MoE Sovereign — Environment Configuration ====
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -- API Keys --
OLLAMA_API_KEY=ollama

# -- Inference Servers (JSON array) --
# Configure your GPU nodes here. Example for a single local Ollama instance:
INFERENCE_SERVERS='[{"name":"gpu-1","url":"http://localhost:11434/v1","gpu_count":1,"token":"ollama","api_type":"ollama","cost_factor":1.0,"vram_gb":12,"enabled":true,"timeout":3600}]'

# -- Core Config --
JUDGE_MODEL=phi4:14b
JUDGE_ENDPOINT=gpu-1
PLANNER_MODEL=phi4:14b
PLANNER_ENDPOINT=gpu-1
GPU_COUNT=1

# -- Expert Models (JSON) --
# Maps expert categories to LLMs. Example with a single general model:
EXPERT_MODELS='{"general":[{"model":"gemma3:12b","endpoints":["gpu-1"],"enabled":true,"forced":true}]}'

# -- Logging --
LOG_LEVEL=INFO
TOKEN_PRICE_EUR=0.00002

# -- Admin UI Auth --
ADMIN_USER=admin
ADMIN_PASSWORD=changeme
ADMIN_SECRET_KEY=

# -- Database (auto-generated by install.sh) --
# MOE_USERDB_URL=postgresql://moe_admin:<password>@terra_checkpoints:5432/moe_userdb
# POSTGRES_CHECKPOINT_URL=postgresql://langgraph:<password>@terra_checkpoints:5432/langgraph

# -- Redis/Valkey --
# REDIS_URL=redis://:<password>@terra_cache:6379/0
# REDIS_PASSWORD=

# -- Neo4j --
# NEO4J_URI=bolt://neo4j-knowledge:7687
# NEO4J_USER=neo4j
# NEO4J_PASS=

# -- Search (optional) --
# SEARXNG_URL=https://search.example.com

# -- ChromaDB --
CHROMA_HOST=chromadb-vector
CHROMA_PORT=8000

# -- Cache Tuning --
SOFT_CACHE_THRESHOLD=0.50
CACHE_MIN_RESPONSE_LEN=150
EXPERT_TIER_BOUNDARY_B=20

# -- Timeouts --
JUDGE_TIMEOUT=3600
EXPERT_TIMEOUT=3600
PLANNER_TIMEOUT=3600

# -- Claude Code Integration (optional) --
# CLAUDE_CODE_MODELS=claude-opus-4-6,claude-sonnet-4-6
# CLAUDE_CODE_MODE=moe_orchestrated
# CLAUDE_CODE_TOOL_MODEL=gemma3:12b
# CLAUDE_CODE_TOOL_ENDPOINT=gpu-1

# -- Expert Templates (optional, JSON array) --
# EXPERT_TEMPLATES='[]'

# -- Claude Code Profiles (optional, JSON array) --
# CLAUDE_CODE_PROFILES='[]'

# -- Host data roots (bind-mount sources for stateful containers) --
# Linux default: /opt/moe-infra
# macOS:        ~/moe-data  (must be inside Docker Desktop's File Sharing list)
# Windows/WSL:  /home/<user>/moe-data
MOE_DATA_ROOT=/opt/moe-infra

# Grafana keeps its own root because operators often back it up separately.
# Linux default: /opt/grafana
# macOS:        ~/moe-grafana
GRAFANA_DATA_ROOT=/opt/grafana

# Optional: separate location for the few-shot example store (defaults to
# ${MOE_DATA_ROOT}/few-shot if unset).
# FEW_SHOT_HOST_DIR=/opt/moe-infra/few-shot
