# ==== MoE Benchmark — Environment Configuration ====
#
# Copy this file to .env and fill in the values for your cluster:
#
#   cp benchmarks/.env.example benchmarks/.env
#
# .env is gitignored and must never be committed.
# =====================================================

# ── MoE API ───────────────────────────────────────────────────────────────────
# API key for the MoE orchestrator (required).
MOE_API_KEY=

# Base URL of the MoE orchestrator API.
MOE_API_BASE=http://localhost:8002

# ── Prometheus ────────────────────────────────────────────────────────────────
MOE_PROM_URL=http://localhost:9090

# ── Benchmark defaults ────────────────────────────────────────────────────────
MOE_EPOCHS=10
MOE_TEMPLATE=moe-m10-gremium-deep
MOE_INGEST_PAUSE=60
MOE_EPOCH_RETRIES=3
MOE_FAILURE_THRESHOLD=4

# ── Runner tuning ─────────────────────────────────────────────────────────────
# Base timeout per API call attempt (seconds). Scales up with each retry.
MOE_TIMEOUT=1200
MOE_MAX_TIMEOUT=3600
MOE_MAX_RETRIES=3
MOE_RETRY_DELAY=30
MOE_PARALLEL_TESTS=1

# ── Judge LLM ─────────────────────────────────────────────────────────────────
# Direct Ollama endpoint for the LLM judge (bypasses the orchestrator pipeline).
MOE_JUDGE_OLLAMA_URL=http://localhost:11434
MOE_JUDGE_MODEL=phi4:14b

# ── Node healing — SSH hostnames ──────────────────────────────────────────────
# SSH hostname for the judge/planner node (must be in ~/.ssh/config or /etc/hosts).
# This node is healed via SSH (docker restart). Leave empty to disable SSH healing.
BENCH_NODE_RTX_SSH=
# SSH hostname for the M10 expert cluster (node running ollama-1..4).
BENCH_NODE_M10A_SSH=
# SSH hostname for the second M10 expert cluster.
BENCH_NODE_M10B_SSH=
# SSH hostname for the specialty node (medical/legal/science).
BENCH_NODE_M60_SSH=
# SSH hostname for the vision node.
BENCH_NODE_GT_SSH=

# ── Node healing — Ollama HTTP base URLs ──────────────────────────────────────
# Primary Ollama endpoint per node (health check + warm-up target).
BENCH_NODE_RTX_URL=http://localhost:11434
BENCH_NODE_M10A_URL=http://localhost:11434
BENCH_NODE_M10B_URL=http://localhost:11434
BENCH_NODE_M60_URL=http://localhost:11434
BENCH_NODE_GT_URL=http://localhost:11434

# ── Node healing — container names ────────────────────────────────────────────
# Space-separated list of Ollama container names on each node.
BENCH_NODE_RTX_CONTAINERS=ollama
BENCH_NODE_M10A_CONTAINERS="ollama-1 ollama-2 ollama-3 ollama-4"
BENCH_NODE_M10B_CONTAINERS="ollama-1 ollama-2 ollama-3 ollama-4"
BENCH_NODE_M60_CONTAINERS=ollama
BENCH_NODE_GT_CONTAINERS=ollama
